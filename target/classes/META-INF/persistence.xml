<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">

    <persistence-unit name="coffee-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.coffeeshop.entity.Client</class>
        <class>com.coffeeshop.entity.Rate</class>
        <class>com.coffeeshop.entity.Subscription</class>
        <class>com.coffeeshop.entity.Package</class>
        <class>com.coffeeshop.entity.Review</class>
        <class>com.coffeeshop.entity.TasteDescriptor</class>
        <class>com.coffeeshop.entity.GrainVariety</class>
        <class>com.coffeeshop.entity.Farmer</class>
        <class>com.coffeeshop.entity.Plantation</class>
        <class>com.coffeeshop.entity.RoastingProfile</class>
        <class>com.coffeeshop.entity.FinishedProduct</class>
        <class>com.coffeeshop.entity.PackageCompositionId</class>
        <class>com.coffeeshop.entity.PackageComposition</class>
        <class>com.coffeeshop.entity.ReviewItemId</class>
        <class>com.coffeeshop.entity.ReviewItem</class>

        <properties>
            <!-- Отдельная БД "coffee" в том же контейнере lab-psql (порт 5432), что и рабочая
                 БД postgres/shop из JDBC-версии. Базы внутри одного контейнера полностью
                 изолированы друг от друга, поэтому это не пересекается с твоими JDBC-данными. -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/coffee"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
            <property name="jakarta.persistence.jdbc.password"  value="postgres"/>
            <property name="jakarta.persistence.jdbc.driver"
                      value="org.postgresql.Driver"/>

            <property name="hibernate.connection.provider_class"
                      value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <property name="hibernate.hikari.maximumPoolSize"  value="10"/>
            <property name="hibernate.hikari.minimumIdle"      value="2"/>

            <property name="hibernate.hbm2ddl.auto"           value="create"/>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>

            <!-- show_sql=false — SQL-запросы не выводятся в консоль, чтобы не мешать
                 консольному меню. Для отладки можно временно включить (true) -->
            <property name="hibernate.show_sql"                value="false"/>
            <property name="hibernate.format_sql"              value="true"/>
            <property name="hibernate.highlight_sql"           value="true"/>
            <property name="hibernate.use_sql_comments"        value="true"/>

            <property name="hibernate.jdbc.batch_size"         value="25"/>
            <property name="hibernate.order_inserts"           value="true"/>
            <property name="hibernate.order_updates"           value="true"/>

            <property name="hibernate.connection.charSet"      value="UTF-8"/>
        </properties>
    </persistence-unit>
</persistence>
